# Local environment — real secrets, never commit
.env

# Postgres data directory — large binary files
data/

# Backup files (Phase 2 scripts will write here)
backups/

# BBjServices build-context / asset folder (bbj-services template).
# Holds the license-gated BBj installer JAR(s) + certificate.bls + the operator's
# combinations.json, and the Dockerfile/playback.properties copied in as build
# context. License-gated + large binaries — never commit (CLAUDE.md secrets rule).
# The canonical Dockerfile/playback.properties/combinations.example.json live under
# templates/bbj-services/ and ARE version-controlled.
bbj-assets/

# ── Terraform noise ───────────────────────────────────────────────────────────
# Generated by terraform init / apply when templates are validated or applied locally.
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# .terraform.lock.hcl is intentionally NOT ignored — committing provider lock
# files (with exact SHA hashes) aids reproducibility across machines and CI,
# consistent with this repo's pin-everything ethos (CLAUDE.md). If a lock file
# appears in templates/*, it should be committed.

# ── OS cruft ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor scratch files ──────────────────────────────────────────────────────
# .vscode/ is NOT ignored — a repo may want to commit shared launch/settings.
# Only transient editor scratch files are excluded here.
*.swp
*.swo
.idea/
*.code-workspace

# ── Coder CLI local config ────────────────────────────────────────────────────
# The coder CLI writes session tokens and config to ~/.coderv2 by default.
# If a maintainer runs `coder login` from the repo root, this dir could appear.
.coderv2/
