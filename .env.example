# ── Coder Server ──────────────────────────────────────────────────────────────

# The public URL operators and workspaces use to reach the Coder server.
# Setting this to a real URL disables the *.try.coder.app dev tunnel.
# Must be reachable from workspace containers — 127.0.0.1 only works for
# Docker-local templates.
CODER_ACCESS_URL=https://coder.example.com

# Wildcard subdomain for workspace app URLs (e.g. *.coder.example.com).
# Do NOT use a top-level domain (e.g. *.workspaces) — browsers reject cookies
# from top-level domains, breaking workspace apps.
CODER_WILDCARD_ACCESS_URL=*.coder.example.com

# Coder image version. Default is v2.33.8 (stable track).
# Change only when intentionally upgrading.
CODER_VERSION=v2.33.8

# Registry override — uncomment to use a different image registry.
# CODER_REPO=ghcr.io/coder/coder

# ── Google login (OIDC, optional) ─────────────────────────────────────────────
# Coder signs in Google users via its generic OIDC mechanism. It stays DISABLED
# until CODER_OIDC_CLIENT_ID is set, so leaving these blank keeps the default
# username/password login.
#
# Setup (Google Cloud Console → APIs & Services → Credentials):
#   1. Create an OAuth client ID (type: Web application).
#   2. Add this authorized redirect URI (must match CODER_ACCESS_URL above):
#        https://coder.example.com/api/v2/users/oidc/callback
#   3. Copy the Client ID / Client Secret into the two variables below.
# Google sign-in needs a reachable HTTPS CODER_ACCESS_URL — the callback
# cannot be 127.0.0.1.

CODER_OIDC_ISSUER_URL=https://accounts.google.com
CODER_OIDC_CLIENT_ID=your-google-oauth-client-id
CODER_OIDC_CLIENT_SECRET=your-google-oauth-client-secret
CODER_OIDC_SCOPES=openid,profile,email

# Restrict logins to one or more email domains (comma-separated). Enforced by
# Coder itself — no Google-side config needed. Leave empty to allow any Google
# account. Example below limits sign-in to @basis.cloud addresses.
CODER_OIDC_EMAIL_DOMAIN=basis.cloud

# ── PostgreSQL ────────────────────────────────────────────────────────────────

POSTGRES_USER=coder
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=coder

# ── Postgres storage (optional bind mount override) ───────────────────────────
# Default: the cross-platform named volume 'coder_pgdata' (no setup required,
# works on macOS, Windows, and Linux Docker Desktop).
#
# To use a host bind mount instead (Linux only — VirtioFS on macOS/Windows
# denies the required chown and will crash-loop Postgres):
#   1. Uncomment the line below.
#   2. mkdir -p ./data/postgres
#   3. sudo chown -R 999:999 ./data/postgres
#   Then run: docker compose up -d
#
# CODER_PG_DATA_DIR=./data/postgres

# ── BBjServices template ───────────────────────────────────────────────────────
# These variables are required to build and use the templates/bbj-services/ template.
# Real values go ONLY in the gitignored .env file — never here.

# Host folder bind-mounted read-only at /mnt/bbj-assets inside the coder service.
# Must contain: BBj*.jar, certificate.bls, and a copy of the template's Dockerfile
# and playback.properties (the Docker build context for the bbj-services image).
# The folder must be readable by the coder container (check Docker socket/group perms).
BBJ_ASSETS_PATH=./bbj-assets

# BLS license server host:port — passed as the LICENSE_SERVER Docker build-arg
# and sed'd into playback.properties at image build time (replacing LICENSE_SERVER_PLACEHOLDER).
# Must be reachable from the Docker host when `coder templates push` triggers an image build.
# Example: bls.example.com:2002
BBJ_LICENSE_SERVER=your-bls-host:2002
